# ==============================================================================
# AUTH-SERVICE - MAIN CONFIGURATION
# ==============================================================================
APP_NAME=auth-service
PORT=8082
ENV=staging
APP_VERSION=0.1.0
SERVER_HEADER=ZeroDayZ7
PREFORK=false

IDLE_TIMEOUT=30s
READ_TIMEOUT=15s
WRITE_TIMEOUT=15s

# TTL dla JWT
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# ==============================================================================
# DATABASE (PostgreSQL) - Adresy klastrowe
# ==============================================================================
DB_HOST=db-auth
DB_PORT=5432
DB_NAME=auth_db
DB_SSLMODE=disable

DB_MAX_OPEN_CONNS=50
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=30m

# ==============================================================================
# INFRASTRUCTURE
# ==============================================================================
REDIS_HOST=redis-auth
REDIS_PORT=6379
REDIS_DB=0

REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=2
REDIS_POOL_TIMEOUT=4s
REDIS_TIMEOUT=5s
REDIS_SESSION_TTL=60m

OTEL_ENABLED=false
SHUTDOWN_TIMEOUT=5s