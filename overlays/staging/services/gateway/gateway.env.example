# ==============================================================================
# GATEWAY - MAIN CONFIGURATION
# ==============================================================================
APP_NAME=Gateway
PORT=8081
ENV=staging
APP_VERSION=2.1.1
BODY_LIMIT_MB=2
SERVER_HEADER=ZeroDayZ7/Gateway
PREFORK=false
CASE_SENSITIVE=true
STRICT_ROUTING=false

IDLE_TIMEOUT=30s
READ_TIMEOUT=15s
WRITE_TIMEOUT=15s

# ==============================================================================
# SECURITY & AUTH
# ==============================================================================
CORS_ALLOW_ORIGINS=*

# ==============================================================================
# INFRASTRUCTURE
# ==============================================================================
# Redis Connection (K3s)
REDIS_HOST=redis-auth
REDIS_PORT=6379
REDIS_DB=0

# Redis Pool & Timeouts
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=2
REDIS_POOL_TIMEOUT=4s
REDIS_TIMEOUT=5s

# Sessions
REDIS_SESSION_PREFIX=session:
REDIS_SESSION_TTL=60m

# Telemetry (OTEL)
OTEL_ENABLED=false
OTEL_ENDPOINT=otel-collector:4318
OTEL_SERVICE_NAME=gateway

# ==============================================================================
# UPSTREAM SERVICES (Internal K8s DNS)
# ==============================================================================
SERVICE_AUTH_URL=http://auth-service
SERVICE_DOCS_URL=http://citizen-docs
SERVICE_NOTIFY_URL=http://notification-service
SERVICE_USERS_URL=http://citizen-api

# ==============================================================================
# PROXY TUNING
# ==============================================================================
PROXY_MAX_IDLE_CONNS=100
PROXY_MAX_IDLE_CONNS_PER_HOST=20

PROXY_IDLE_CONN_TIMEOUT=90s
PROXY_REQUEST_TIMEOUT=30s
SHUTDOWN_TIMEOUT=5s